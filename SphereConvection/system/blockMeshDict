FoamFile
{
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// superficie analitica a la que proyectaremos el cubo
geometry
{
    sphere
    {
        type   sphere;
        centre (0 0 0);
        radius 0.1;
    }
}

scale 1;

// vertices del cubo inscrito: coordenada = R/sqrt(3)
v  0.05773502;
mv -0.05773502;
// puntos medios de arista sobre la esfera: R/sqrt(2)
a  0.07071067;
ma -0.07071067;

vertices
(
    ($mv $mv $mv)
    ( $v $mv $mv)
    ( $v  $v $mv)
    ($mv  $v $mv)
    ($mv $mv  $v)
    ( $v $mv  $v)
    ( $v  $v  $v)
    ($mv  $v  $v)
);

blocks
(
    hex (0 1 2 3 4 5 6 7) (25 25 25) simpleGrading (1 1 1)
);

// aristas curvas: cada arista del cubo se abomba hacia la esfera
edges
(
    arc 0 1 (0 $ma $ma)   arc 2 3 (0 $a $ma)   arc 6 7 (0 $a $a)    arc 4 5 (0 $ma $a)
    arc 0 3 ($ma 0 $ma)   arc 1 2 ($a 0 $ma)   arc 5 6 ($a 0 $a)    arc 4 7 ($ma 0 $a)
    arc 0 4 ($ma $ma 0)   arc 1 5 ($a $ma 0)   arc 2 6 ($a $a 0)    arc 3 7 ($ma $a 0)
);

// proyecta las 6 caras del cubo sobre la esfera
faces
(
    project (0 4 7 3) sphere
    project (2 6 5 1) sphere
    project (1 5 4 0) sphere
    project (3 7 6 2) sphere
    project (0 3 2 1) sphere
    project (4 5 6 7) sphere
);

boundary
(
    walls                   // toda la superficie de la esfera = 1 patch
    {
        type wall;
        faces
        (
            (0 4 7 3)
            (2 6 5 1)
            (1 5 4 0)
            (3 7 6 2)
            (0 3 2 1)
            (4 5 6 7)
        );
    }
);

