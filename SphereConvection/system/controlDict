FoamFile
{
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     laplacianFoam;

startFrom       startTime;
startTime       0;
stopAt          endTime;
endTime         1000;       // ~ 2*tau de difusion (tau = R^2/DT = 500 s)

deltaT          1.0;
writeControl    timeStep;
writeInterval   10;         // cada 10 s -> ~100 instantes para animar

runTimeModifiable yes;

