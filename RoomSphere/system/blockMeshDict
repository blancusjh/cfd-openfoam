FoamFile
{
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// habitacion: 0.6 (x) x 1.0 (alto, y) x 0.6 (z) [m]
scale 1;

vertices
(
    (-0.3 0.0 -0.3)   // 0
    ( 0.3 0.0 -0.3)   // 1
    ( 0.3 1.0 -0.3)   // 2
    (-0.3 1.0 -0.3)   // 3
    (-0.3 0.0  0.3)   // 4
    ( 0.3 0.0  0.3)   // 5
    ( 0.3 1.0  0.3)   // 6
    (-0.3 1.0  0.3)   // 7
);

blocks
(
    // ~0.03 m por celda -> 20 x 34 x 20 = 13600 celdas de fondo
    hex (0 1 2 3 4 5 6 7) (20 34 20) simpleGrading (1 1 1)
);

boundary
(
    floor
    {
        type wall;
        faces ( (0 1 5 4) );
    }
    ceiling
    {
        type wall;
        faces ( (3 2 6 7) );
    }
    walls
    {
        type wall;
        faces
        (
            (0 4 7 3)   // x-
            (1 2 6 5)   // x+
            (0 3 2 1)   // z-
            (4 5 6 7)   // z+
        );
    }
);

