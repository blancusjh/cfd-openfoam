FoamFile
{
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solver          fluid;

startFrom       startTime;
startTime       0;
stopAt          endTime;
endTime         30;             // s de simulacion (pluma bien desarrollada)

deltaT          0.01;           // paso inicial (se ajusta solo)

writeControl    adjustableRunTime;
writeInterval   0.01;           // guarda cada 0.25 s -> ~120 instantes

purgeWrite      0;
runTimeModifiable yes;

adjustTimeStep  yes;            // paso adaptativo segun Courant
maxCo           0.5;
maxDeltaT       0.1;

// ************************************************************************* //
