FoamFile
{
    format      ascii;
    class       volScalarField;
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 1 0 0 0];

internalField   uniform 300;        // aire de la habitacion a 300 K

boundaryField
{
    hotSphere                       // esfera caliente
    {
        type            fixedValue;
        value           uniform 350;
    }
    floor       { type zeroGradient; }   // suelo aislado
    walls       { type zeroGradient; }   // paredes aisladas
    ceiling
    {
        type            fixedValue;
        value           uniform 300;      // techo frio (sumidero de calor)
    }
}

